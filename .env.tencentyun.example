# 腾讯云 COS 配置文件示例
# 复制此文件为 .env 并填入实际配置

# ==================== 存储后端选择 ====================
# 可选值: oss（阿里云OSS）, cos（腾讯云COS）, mock（Mock模式）
STORAGE_BACKEND=cos

# ==================== 腾讯云 COS 配置 ====================
# API 基础 URL（用于获取 STS 临时凭证）
TENCENT_API_BASE_URL=https://api.example.com

# 场景名称（需要向资源中心申请）
# 示例: imchat（IM聊天）, sale（拍品）等
TENCENT_SCENE_NAME=frontend-automation

# 业务名称英文名（需要向资源中心申请）
TENCENT_BUSINESS_NAME=workflow

# 环境模式（dev/gray/prod）
# dev: 开发环境
# gray: 灰度环境
# prod: 生产环境
TENCENT_MODE=dev

# 认证 Token（可选，主站H5不需要传）
TENCENT_TOKEN=

# X-Secret-Key（安全密钥，可选）
# 优先从 cookie 获取，如果获取不到再从此参数获取
TENCENT_SECRET_KEY=

# ==================== 阿里云 OSS 配置（备用）====================
# 仅当 STORAGE_BACKEND=oss 时使用

# OSS AccessKey ID
OSS_ACCESS_KEY_ID=

# OSS AccessKey Secret
OSS_ACCESS_KEY_SECRET=

# OSS Bucket 名称
OSS_BUCKET=

# OSS Endpoint（如: https://oss-cn-hangzhou.aliyuncs.com）
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# ==================== MasterGo MCP 配置 ====================
# MasterGo MCP Token
MASTERGO_MCP_TOKEN=

# 是否使用 Mock 模式（true/false）
USE_MOCK_MCP=false
