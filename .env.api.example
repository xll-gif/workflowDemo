# ==================== 后端 API 服务配置 ====================
# 此配置文件用于腾讯云 COS 上传 API 服务

# ==================== API 服务配置 ====================
# API 服务端口
PORT=5000

# 是否开启调试模式
DEBUG=false

# API 安全密钥（可选，如果设置了则客户端必须提供 X-Secret-Key）
API_SECRET_KEY=

# ==================== 腾讯云 COS 配置 ====================
# 腾讯云 SecretId（在访问管理 > API密钥管理中获取）
TENCENT_SECRET_ID=your_secret_id_here

# 腾讯云 SecretKey（在访问管理 > API密钥管理中获取）
TENCENT_SECRET_KEY=your_secret_key_here

# COS 存储桶名称
TENCENT_BUCKET=your-bucket-name

# COS 区域（如：ap-shanghai, ap-beijing, ap-guangzhou）
TENCENT_REGION=ap-shanghai

# STS 临时凭证有效期（秒），默认 15 分钟
TENCENT_DURATION_SECONDS=900

# 允许上传的路径前缀（支持通配符）
# 格式：{scene_name}/{business_name}/*
TENCENT_ALLOW_PREFIX=frontend-automation/*

# 自定义加速域名（可选）
# 如果配置了自定义 CDN 域名，将使用该域名返回访问 URL
# 格式：https://your-cdn-domain.com
TENCENT_CUSDOMAIN=

# ==================== 工作流配置（客户端） ====================
# 存储后端选择（仅客户端使用）
STORAGE_BACKEND=cos

# API 基础 URL（仅客户端使用，指向此 API 服务）
TENCENT_API_BASE_URL=http://localhost:5000

# 场景名称（仅客户端使用）
TENCENT_SCENE_NAME=frontend-automation

# 业务名称（仅客户端使用）
TENCENT_BUSINESS_NAME=workflow

# 环境模式（仅客户端使用：dev/gray/prod）
TENCENT_MODE=dev

# 认证 Token（仅客户端使用，可选）
TENCENT_TOKEN=

# X-Secret-Key（仅客户端使用，可选）
TENCENT_SECRET_KEY=
